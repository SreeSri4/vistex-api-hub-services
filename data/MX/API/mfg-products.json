{
  "id": "mfg-products",
  "name": "Product Catalog API",
  "description": "Product & inventory management",
  "baseUrl": "https://api.manufacturing.com/v1",
  "version": "1.0.0",
  "endpoints": [
    {
      "path": "/products",
      "method": "GET",
      "summary": "List all products",
      "tags": [
        "Products"
      ],
      "parameters": [
        {
          "name": "category",
          "type": "string",
          "description": "Product category"
        }
      ],
      "responses": [
        {
          "status": 200,
          "description": "List of products"
        }
      ]
    },
    {
      "path": "/products/{id}",
      "method": "GET",
      "summary": "Get product by ID",
      "tags": [
        "Products"
      ],
      "parameters": [
        {
          "name": "id",
          "type": "string",
          "required": true,
          "description": "Product ID"
        }
      ],
      "responses": [
        {
          "status": 200,
          "description": "Product details"
        },
        {
          "status": 404,
          "description": "Product not found"
        }
      ]
    }
  ]
}