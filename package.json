{
  "name": "openapi-hub",
  "version": "1.0.0",
  "description": "Multi-tenant OpenAPI documentation hub for Cloud Foundry",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "concurrently -k -n web,api -c blue,green \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite",
    "dev:server": "cross-env PORT=4000 tsx watch src/server/index.ts",
    "build": "vite build && npm run build:server",
    "build:server": "tsc src/server/index.ts --outDir dist --module esnext --target es2020 --moduleResolution node --esModuleInterop",
    "preview": "vite preview",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "express": "^4.18.2",
    "js-yaml": "^4.1.0",
    "multer": "^1.4.5-lts.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.4",
    "swagger-ui-react": "^5.1.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.5",
    "@types/multer": "^1.4.11",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/swagger-ui-react": "^5.18.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}